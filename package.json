{
  "name": "@reuters-graphics/spectre",
  "version": "0.1.0",
  "description": "Spectre — a local cross-browser UI-audit harness. Runs a Playwright audit across every route × emulated device you care about and aggregates console errors, network failures, horizontal-overflow offenders, axe-core a11y violations, screenshots and pixel-diffs into a browsable HTML report + Markdown summary + CI JSON + an LLM post-mortem prompt.",
  "type": "module",
  "main": "./index.js",
  "bin": {
    "spectre": "./index.js"
  },
  "exports": {
    ".": "./index.js",
    "./report": "./report.js",
    "./postmortem": "./postmortem.js",
    "./discover": "./discover.js",
    "./config": "./playwright.local.config.ts",
    "./routes-example": "./routes.example.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "spectre": "node ./index.js",
    "local": "node ./index.js local",
    "report": "node ./index.js report",
    "clean": "node ./index.js clean"
  },
  "files": [
    "index.js",
    "report.js",
    "postmortem.js",
    "discover.js",
    "audit.spec.ts",
    "routes.example.ts",
    "playwright.local.config.ts",
    "README.md"
  ],
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "picocolors": "^1.1.0"
  },
  "peerDependencies": {
    "@playwright/test": "^1.60.0"
  },
  "optionalDependencies": {
    "sharp": "^0.33.0"
  },
  "keywords": [
    "playwright",
    "ui-audit",
    "cross-browser",
    "accessibility",
    "axe-core",
    "visual-regression",
    "screenshots",
    "reuters-graphics",
    "spectre"
  ],
  "author": "Reuters Graphics",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reuters-graphics/spectre.git"
  },
  "homepage": "https://github.com/reuters-graphics/spectre#readme",
  "bugs": {
    "url": "https://github.com/reuters-graphics/spectre/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
